.DS_Store
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtualenvs (any depth)
.venv/
venv/

# Env files (any depth; root .env* also covered by /.* below)
.env
.env.*
!.env.example

*.log
*.logs
.logs

# Docs
docs/

# QA / installer scratch (local-only)
QA-Logs/
.tmp/
.pytest_cache/
.pytest_tmp/
.ruff_cache/

# Generated or tool-managed files (no leading dot — not covered by /.* alone)
AGENTS.md
!AGENTS.md.template

CLAUDE.md
CLAUDE.md.bak

# /.github/ is tracked (protocol); ignore only this generated file
.github/copilot-instructions.md

WARP.md
WARP.md.bak
opencode.json
opencode.json.bak
config/opencode_mcp.json
config/zed_mcp.json
firebender.json
firebender.json.bak
BRAIN_MCP_HUB.code-workspace
config.toml
config.toml.bak
CRUSH.md

# Tests are dev-only (not needed on consumer installs)
tests/*
!tests/test_workspace_primer_hooks.py
!tests/test_scriptlib.py
!tests/test_env_probe_codex.py

# Ruler outputs at repo root (no leading dot)
/AGENTS.md
/AGENTS.md.bak

# BEGIN BRAINDRAIN GITIGNORE PROTOCOL — do not remove (maintained by prime_workspace)
# Root-level dotfiles/dotdirs are local-only (IDE, MCP, secrets). Add ! exceptions only for paths that must ship.
# Ruler runs with --no-gitignore; this block is the single policy for root .* paths.
/.*
!/.github/
!/.gitignore
!/.gitattributes
!/.gitmodules
!/.env.example
# `.cursor/` stays fully ignored; ship agents/skills via config/templates/cursor-* (deploy: prime_workspace).
# If your team commits other root dotdirs (e.g. .husky), add: !/.husky/
# `.devdocs/` is covered by `/.*` above — local-only; never add ! exceptions for it.
# END BRAINDRAIN GITIGNORE PROTOCOL
