#!/bin/bash
# BRAINDRAIN MCP Server Launcher
# Self-detecting: works from any clone location on any machine.
# IDEs point at this file directly — no hardcoded paths needed.

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

# GUI-launched IDEs (Cursor) often omit Homebrew/nvm from PATH; context-mode needs npx.
_prepend_path() {
  for dir in \
    "/opt/homebrew/bin" \
    "/usr/local/bin" \
    "/opt/local/bin" \
    "${HOME}/.fnm/current/bin" \
    "${HOME}/.volta/bin" \
    "${HOME}/.asdf/shims" \
    "${HOME}/.local/share/pnpm" \
    "${HOME}/.npm-global/bin"
  do
    if [[ -d "$dir" ]]; then
      case ":${PATH}:" in
        *":${dir}:"*) ;;
        *) PATH="${dir}:${PATH}" ;;
      esac
    fi
  done
  if [[ -d "${NVM_DIR:-${HOME}/.nvm}/versions/node" ]]; then
    _nvm_latest="$(ls -1 "${NVM_DIR:-${HOME}/.nvm}/versions/node" 2>/dev/null | sort -V | tail -1)"
    if [[ -n "$_nvm_latest" ]]; then
      _nvm_bin="${NVM_DIR:-${HOME}/.nvm}/versions/node/${_nvm_latest}/bin"
      case ":${PATH}:" in
        *":${_nvm_bin}:"*) ;;
        *) PATH="${_nvm_bin}:${PATH}" ;;
      esac
    fi
  fi
}
_prepend_path
VENV_PYTHON="$REPO/.venv/bin/python"
PYPROJECT_FILE="$REPO/pyproject.toml"

_choose_python() {
  local candidates=("$@")
  local candidate=""
  for candidate in "${candidates[@]}"; do
    if [[ "$candidate" == /* ]]; then
      [[ -x "$candidate" ]] || continue
    else
      candidate="$(command -v "$candidate" 2>/dev/null || true)"
      [[ -n "$candidate" ]] || continue
    fi
    if "$candidate" -c "import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 11) else 1)" >/dev/null 2>&1; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "[braindrain] Missing venv at $VENV_PYTHON; bootstrapping..." >&2
  BOOTSTRAP_PYTHON="${BRAINDRAIN_BOOTSTRAP_PYTHON:-}"
  if [[ -n "$BOOTSTRAP_PYTHON" && -x "$BOOTSTRAP_PYTHON" ]]; then
    if ! "$BOOTSTRAP_PYTHON" -c "import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 11) else 1)" >/dev/null 2>&1; then
      echo "[braindrain] BRAINDRAIN_BOOTSTRAP_PYTHON is below Python 3.11: $BOOTSTRAP_PYTHON" >&2
      BOOTSTRAP_PYTHON=""
    fi
  fi
  if [[ -z "$BOOTSTRAP_PYTHON" ]]; then
    BOOTSTRAP_PYTHON="$(_choose_python \
      "/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14" \
      "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3.13" \
      "/Library/Frameworks/Python.framework/Versions/3.12/bin/python3.12" \
      "/Library/Frameworks/Python.framework/Versions/3.11/bin/python3.11" \
      "/opt/homebrew/bin/python3.14" \
      "/opt/homebrew/bin/python3.13" \
      "/opt/homebrew/bin/python3.12" \
      "/opt/homebrew/bin/python3.11" \
      python3.14 python3.13 python3.12 python3.11 python3 || true)"
  fi
  if [[ -z "$BOOTSTRAP_PYTHON" ]]; then
    echo "[braindrain] Could not find Python 3.11+ to rebuild .venv." >&2
    echo "[braindrain] Fix: install Python 3.11+ and run ./install.sh" >&2
    exit 1
  fi
  "$BOOTSTRAP_PYTHON" -m venv "$REPO/.venv" || exit 1
  if [[ -f "$PYPROJECT_FILE" ]]; then
    if command -v uv >/dev/null 2>&1; then
      (cd "$REPO" && uv sync) || {
        echo "[braindrain] Failed to install Python dependencies (uv sync)." >&2
        echo "[braindrain] Fix: run ./install.sh" >&2
        exit 1
      }
    else
      "$REPO/.venv/bin/pip" install -e "$REPO" || {
        echo "[braindrain] Failed to install Python dependencies." >&2
        echo "[braindrain] Fix: run ./install.sh (or .venv/bin/pip install -e .)." >&2
        exit 1
      }
    fi
  fi
fi

# Notify-only update awareness (never blocks startup or pulls automatically).
if [[ -x "$VENV_PYTHON" ]]; then
  _bd_update_out="$("$VENV_PYTHON" - <<'PY' "$REPO" 2>/dev/null || true
import subprocess
import sys
from pathlib import Path

from braindrain.updater import maybe_background_check, startup_notify_message

root = Path(sys.argv[1])
if maybe_background_check(root):
    subprocess.Popen(
        [
            sys.executable,
            "-m",
            "braindrain.updater",
            "check",
            "--repo-root",
            str(root),
            "--quiet",
        ],
        cwd=root,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
message = startup_notify_message(root)
if message:
    print(message)
PY
)" || true
  if [[ -n "$_bd_update_out" ]]; then
    echo "$_bd_update_out" >&2
  fi
fi

exec "$VENV_PYTHON" -m braindrain.server stdio
