## BRAINDRAIN environment variables (example)
##
## Copy to .env.dev / .env.prod and load via your shell or launcher script.
## DO NOT commit real secrets.

# Optional: override hub config location
# BRAINDRAIN_CONFIG=/Volumes/devnvme/Development/BRAIN_MCP_HUB/config/hub_config.yaml

# GitHub MCP (deferred)
# GITHUB_TOKEN=ghp_...

# Optional embeddings / semantic search providers
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# HUGGINGFACE_API_KEY=hf_...

# Optional local model endpoints
# OLLAMA_HOST=http://localhost:11434
# LMSTUDIO_BASE_URL=http://192.168.1.202:1234/v1

# Optional FileScopeMCP wiring (if you build/install it separately)
# FILESCOPE_MCP_SERVER_JS=/usr/local/bin/filescope-mcp-server.js
# FILESCOPE_BASE_DIR=/Volumes/devnvme/Development/BRAIN_MCP_HUB

